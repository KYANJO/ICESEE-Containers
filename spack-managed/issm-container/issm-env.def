Bootstrap: docker
From: docker.io/bkyanjo/issm-lean:v1.0

%post
    set -eu

    apt-get update && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        && rm -rf /var/lib/apt/lists/*

    cat << 'EOF' > /opt/activate-issm-env.sh
#!/bin/sh
set -e

. /opt/runtime-env/issm-env.sh

export MLM_LICENSE_FILE="${MLM_LICENSE_FILE:-1711@matlablic.ecs.gatech.edu}"
export ISSM_DIR="${ISSM_DIR:-/opt/ISSM}"
export PYTHONPATH="/opt:${PYTHONPATH:-}"

if [ -f /opt/ISSM/etc/environment.sh ]; then
    set +u
    . /opt/ISSM/etc/environment.sh
    set -u
fi
EOF

    chmod +x /opt/activate-issm-env.sh

%environment
    export OMP_NUM_THREADS=1
    export OPENBLAS_NUM_THREADS=1
    export HDF5_MPI=ON
    export ISSM_DIR=/opt/ISSM
    export MLM_LICENSE_FILE=1711@matlablic.ecs.gatech.edu
    export PYTHONPATH=/opt:${PYTHONPATH}
    export PATH=/opt/ISSM/bin:/opt/matlab/R2024b/bin:${PATH}

%runscript
    #!/bin/sh
    set -e
    . /opt/activate-issm-env.sh

    if [ "$#" -gt 0 ]; then
        exec "$@"
    else
        exec /bin/bash
    fi

%test
    . /opt/activate-issm-env.sh
    test -f /opt/ISSM/etc/environment.sh
    test -d /opt/ISSM/bin
    mpicc --version
    matlab -batch "disp('MATLAB OK')"

%labels
    Author Brian Kyanjo
    ContactEmail briankyanjo@u.boisestate.edu
    Name ISSM Lean Apptainer
    Description MATLAB + Spack-built ISSM lean runtime for cluster use

%help
    This Apptainer image starts from:
      docker.io/bkyanjo/issm-lean:v1.0

    It provides:
      - MATLAB R2024b
      - ISSM installed at /opt/ISSM
      - MPICH runtime from the container
      - Precomputed runtime environment in /opt/runtime-env/issm-env.sh

    Helper script:
      /opt/activate-issm-env.sh

    Typical usage:
      apptainer exec issm-env.sif /opt/activate-issm-env.sh matlab -batch "issmversion"
      apptainer exec issm-env.sif /opt/activate-issm-env.sh mpicc --version
      apptainer shell issm-env.sif