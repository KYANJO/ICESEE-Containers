Bootstrap: docker
From: docker.io/bkyanjo/spack-icepack:latest

%post
    set -eu

    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    cat << 'EOF' > /opt/activate_icepack.sh
#!/bin/sh
set -e

. /opt/spack-src/share/spack/setup-env.sh
spack env activate /opt/spack-environment

MPI_DIR="$(spack location -i openmpi)"
PETSC_DIR="$(spack location -i petsc)"

export PATH="/opt/venv-firedrake/bin:${MPI_DIR}/bin:${PATH}"
export LD_LIBRARY_PATH="${MPI_DIR}/lib:${PETSC_DIR}/lib:${LD_LIBRARY_PATH:-}"
export CC="${MPI_DIR}/bin/mpicc"
export CXX="${MPI_DIR}/bin/mpicxx"
export FC="${MPI_DIR}/bin/mpifort"
export MPICC="${MPI_DIR}/bin/mpicc"
export MPICXX="${MPI_DIR}/bin/mpicxx"
export MPIFC="${MPI_DIR}/bin/mpifort"
export PETSC_DIR="${PETSC_DIR}"
export HDF5_MPI=ON
unset PETSC_ARCH
EOF

    cat << 'EOF' > /opt/set_persistent_dir.sh
#!/bin/sh
set -e

if [ -d "/scratch" ]; then
    PERSISTENT_DIR="/scratch/${USER:-$(id -un)}/icepack_cache"
else
    PERSISTENT_DIR="/tmp/${USER:-$(id -un)}/icepack_cache"
fi

mkdir -p "$PERSISTENT_DIR/pyop2"
mkdir -p "$PERSISTENT_DIR/tsfc"
mkdir -p "$PERSISTENT_DIR/xdg"

export PERSISTENT_DIR
export PYOP2_CACHE_DIR="$PERSISTENT_DIR/pyop2"
export FIREDRAKE_TSFC_KERNEL_CACHE_DIR="$PERSISTENT_DIR/tsfc"
export XDG_CACHE_HOME="$PERSISTENT_DIR/xdg"
EOF

    chmod +x /opt/activate_icepack.sh /opt/set_persistent_dir.sh

%environment
    export OMP_NUM_THREADS=1
    export OPENBLAS_NUM_THREADS=1
    export HDF5_MPI=ON
    export PERSISTENT_DIR=/tmp/${USER}/icepack_cache
    export PYOP2_CACHE_DIR=${PERSISTENT_DIR}/pyop2
    export FIREDRAKE_TSFC_KERNEL_CACHE_DIR=${PERSISTENT_DIR}/tsfc
    export XDG_CACHE_HOME=${PERSISTENT_DIR}/xdg
    export PATH=/opt/venv-firedrake/bin:${PATH}

%runscript
    #!/bin/sh
    set -e
    . /opt/activate_icepack.sh
    . /opt/set_persistent_dir.sh

    if [ "$#" -gt 0 ]; then
        exec "$@"
    else
        exec /bin/bash
    fi

%test
    . /opt/activate_icepack.sh
    . /opt/set_persistent_dir.sh
    python -c "import firedrake; print('firedrake ok')"
    python -c "import icepack; print('icepack ok')"

%labels
    Author Brian Kyanjo
    ContactEmail briankyanjo@u.boisestate.edu
    Name Spack-Icepack container

%help
    This Apptainer container starts from docker.io/bkyanjo/spack-icepack:latest.

    It provides:
      - Spack-managed Python/MPI/PETSc stack
      - Firedrake installed in /opt/venv-firedrake
      - Icepack installed into the same environment
      - Runtime helpers for cache directories on /scratch or /tmp